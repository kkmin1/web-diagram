ap="Flat" Style="Solid" Width="33"/><FILLBRUSH><WINDOWBRUSH Alpha="0" FaceColor="16777215" HatchColor="0"/></FILLBRUSH><SHADOW Alpha="0" Color="11711154" OffsetX="0" OffsetY="0" Type="0"/><DRAWTEXT Editable="false" LastWidth="1260"><TEXTMARGIN Bottom="283" Left="283" Right="283" Top="283"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Center"><P ParaShape="3" Style="0"><TEXT CharShape="10"><CHAR>b</CHAR></TEXT></P></PARALIST></DRAWTEXT></DRAWINGOBJECT></RECTANGLE><CHAR/></TEXT></P><P ParaShape="13" Style="0"><TEXT CharShape="10"><CHAR>                 </CHAR></TEXT></P><P ParaShape="13" Style="0"><TEXT CharShape="10"/></P><P ParaShape="13" Style="0"><TEXT CharShape="10"/></P><P ParaShape="13" Style="0"><TEXT CharShape="10"><CHAR>             </CHAR></TEXT></P><P ColumnBreak="false" PageBreak="true" ParaShape="13" Style="0"><TEXT CharShape="10"/></P><P ParaShape="13" Style="0"><TEXT CharShape="10"/></P><P ParaShape="14" Style="0"><TEXT CharShape="10"><CHAR>(그림 1)에는  a,  b, 2 개의 균형점이 존재한다.</CHAR></TEXT></P><P ParaShape="14" Style="0"><TEXT CharShape="10"><CHAR> </CHAR></TEXT></P><P ParaShape="14" Style="0"><TEXT CharShape="10"><CHAR>b는 시간이 흘러도 변하지 않고 안정적이므로 국부적으로 안정상태임(locally stable)을 알 수 있다. </CHAR></TEXT></P><P ParaShape="15" Style="0"><TEXT CharShape="10"/></P><P ParaShape="14" Style="0"><TEXT CharShape="10"><CHAR>a에서 근방으로 조금만 이탈해도 오른쪽으로 이동하므로 a는 시간이 흐름에 따라 안정적(unstable)이지 않다. </CHAR></TEXT></P><P ParaShape="14" Style="0"><TEXT CharShape="10"><CHAR> </CHAR></TEXT></P><P ParaShape="14" Style="0"><TEXT CharShape="10"><CHAR>아래 (그림 2)를 보자.</CHAR></TEXT></P><P ParaShape="14" Style="0"><TEXT CharShape="10"/></P><P ParaShape="14" Style="0"><TEXT CharShape="10"/></P><P ParaShape="14" Style="0"><TEXT CharShape="10"><CONTAINER><SHAPEOBJECT InstId="1931601651" Lock="false" NumberingType="Figure" TextWrap="InFrontOfText" ZOrder="149"><SIZE Height="19200" HeightRelTo="Absolute" Protect="false" Width="28500" WidthRelTo="Absolute"/><PO